{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ant-design/pro-layout": ["./components/pro-layout-shim"],
      "@ant-design/pro-table": ["./components/pro-table-shim"],
      "@/*": ["./*"],
    },
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "pages/api/ocr.js"],
  "exclude": ["node_modules"]
}
